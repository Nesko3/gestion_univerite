package com.example.demo.entity;

import jakarta.persistence.*;

import java.time.LocalDate;

@Entity
public class Enrollement {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    private LocalDate enrollementDate;

    @ManyToOne
    private Student student;

    @ManyToOne
    private Course course;

    public Enrollement() {}

    public Enrollement(Long id, LocalDate enrollmentDate, Student student, Course course) {
        this.id = id;
        this.enrollementDate = enrollmentDate;
        this.student = student;
        this.course = course;
    }

	public Long getId() {
		return id;
	}

	public void setId(Long id) {
		this.id = id;
	}

	public LocalDate getEnrollmentDate() {
		return enrollementDate;
	}

	public void setEnrollmentDate(LocalDate enrolelmentDate) {
		this.enrollementDate = enrollementDate;
	}

	public Student getStudent() {
		return student;
	}

	public void setStudent(Student student) {
		this.student = student;
	}

	public Course getCourse() {
		return course;
	}

	public void setCourse(Course course) {
		this.course = course;
	}

}
